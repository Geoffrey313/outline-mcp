# --- Upstream Outline API ---------------------------------------------------
OUTLINE_API_URL=https://your-outline.example.com/api
# Personal API token from Outline -> Settings -> API Tokens.
# Required for stdio, Gateway and Open modes. Ignored in Passthrough.
OUTLINE_API_TOKEN=

# --- Transport --------------------------------------------------------------
# stdio (default, per-user local) | http (hosted, Streamable HTTP)
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=9000

# --- Inbound auth (http mode: choose EXACTLY ONE) ---------------------------
# Passthrough: each client sends its own Outline token as a Bearer header.
MCP_ALLOW_OUTLINE_TOKEN_AUTH=false
# Gateway: clients present this shared secret; upstream uses OUTLINE_API_TOKEN.
MCP_AUTH_TOKEN=
# Open: no inbound auth; upstream uses OUTLINE_API_TOKEN. Private networks only.
MCP_ALLOW_UNAUTHENTICATED=false

# Required in http mode: comma-separated public host(s) for DNS-rebinding protection.
MCP_ALLOWED_HOSTS=outline-mcp.example.com
# Optional: comma-separated allowed Origins. Defaults to http(s)://<each allowed host>.
# Set explicitly if clients send an Origin that differs from the request Host.
MCP_ALLOWED_ORIGINS=

# --- Passthrough session-token cache ----------------------------------------
MCP_SESSION_TTL=1800
MCP_SESSION_MAX=10000

# --- Behaviour --------------------------------------------------------------
# Drop all write tools (search/read only) regardless of token power.
OUTLINE_MCP_READONLY=false
DEFAULT_LIMIT=25
MAX_LIMIT=100
REQUEST_TIMEOUT_SECONDS=30
LOG_LEVEL=info
